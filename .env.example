# ── Database ──────────────────────────────────────────────────────────────────
#
# Option A — Vercel Postgres (added via Vercel Dashboard > Storage > Postgres)
#   Vercel injects these automatically when the store is linked to your project.
#   Copy them here for local dev by running: vercel env pull .env.local
#
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require
POSTGRES_URL_NON_POOLING=postgres://user:password@host:5432/dbname?sslmode=require
#
# Option B — Neon / Supabase / any external Postgres
#   Used as a fallback when the POSTGRES_URL* vars above are not set.
#
# DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ── Email (Resend) ────────────────────────────────────────────────────────────
#   Sign up free at https://resend.com → API Keys → Create key.
#   Add in Vercel Dashboard > Project > Settings > Environment Variables.
#   If not set, approval emails are silently skipped (no crash).
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
#
#   The "from" address shown in the email.
#   During testing you can leave this blank — Resend's sandbox address is used.
#   For production, verify your domain at resend.com and set e.g.:
#     RESEND_FROM_EMAIL=SEO Audit <seo-audit@yourcompany.com>
#
# RESEND_FROM_EMAIL=SEO Audit <seo-audit@yourcompany.com>

# ── Vercel Blob ────────────────────────────────────────────────────────────────
#   Added via Vercel Dashboard > Storage > Blob.
#   Vercel injects this automatically; copy it locally via: vercel env pull .env.local
#
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx
